# ─── Client-side Vite env vars (VITE_ prefix required) ───
VITE_API_BASE=http://localhost:8787
VITE_CLERK_PUBLISHABLE_KEY=

# ─── Clerk (server-side secrets — set via CF Pages dashboard) ───
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# ─── Stripe ───
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Cloudflare ───
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ─── Web3 / Solana ───
SOLANA_RPC_URL=
SOLANA_TREASURY=
SOL_USD_RATE=69.52
USDC_USD_RATE=1.00

# ─── OAuth Providers (set via CF Pages dashboard) ───
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# ─── Email & Notifications ───
# ADMIN_EMAILS=admin@example.com

# ─── App Security ───
# APP_SECRET=<random-64-char-hex>

# ─── Feature Flags ───
ENVIRONMENT=development
VAULT_DOMAIN=localhost
ENABLE_RATE_LIMITING=true
ENABLE_SECURITY_HEADERS=true
