# The Vault DFW — required configuration.
# Copy this file to `.env` and populate real values for local development.

# Backend API URL
VITE_API_BASE=http://localhost:8787

# OAuth Provider Credentials (set via Cloudflare Pages secrets in prod)
# APP_SECRET — required for JWT signing
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET — Google OAuth
# GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET — GitHub OAuth
# X_CLIENT_ID / X_CLIENT_SECRET — X (Twitter) OAuth
# APPLE_CLIENT_ID / APPLE_CLIENT_SECRET — Apple OAuth

GOOGLE_CLIENT_ID=
